<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="反扫盘 · 设置" Width="500" Height="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#F5F6FA"
        FontFamily="Microsoft YaHei UI">
  <Window.Resources>
    <Style TargetType="CheckBox">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="#2D3436"/>
      <Setter Property="Margin" Value="0,8,0,8"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Width" Value="100"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Background" Value="#6C5CE7"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#5A4BD1"/>
        </Trigger>
        <Trigger Property="IsPressed" Value="True">
          <Setter Property="Background" Value="#4A3DB5"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="StartStopButton" TargetType="Button">
      <Setter Property="Width" Value="100"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#4A3DB5"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="OutlineButton" TargetType="Button">
      <Setter Property="Width" Value="180"/>
      <Setter Property="Height" Value="38"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="#6C5CE7"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="#6C5CE7"/>
      <Setter Property="BorderThickness" Value="1.5"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Margin" Value="0,0,0,10"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#F0EDFF"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>
  <Grid Margin="30,20,30,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <TextBlock Text="反扫盘" FontSize="22" FontWeight="Bold" Foreground="#2D3436"/>
      <TextBlock Text="ACE-Guard 进程监控 · 角色悬浮窗" FontSize="12" Foreground="#888" Margin="0,4,0,0"/>
    </StackPanel>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" VerticalAlignment="Center">
        <TextBlock Text="常规设置" FontSize="13" FontWeight="SemiBold" Foreground="#B2BEC3" Margin="0,0,0,8"/>
        <CheckBox x:Name="ChkAutoStart" Content="开机自启动"/>
        <CheckBox x:Name="ChkShowOverlay" Content="默认打开悬浮窗"/>
      </StackPanel>

      <Border Grid.Column="1" Width="1" Background="#E0E0E0" Margin="20,10"/>

      <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="自定义" FontSize="13" FontWeight="SemiBold" Foreground="#B2BEC3" Margin="0,0,0,12"/>
        <Button x:Name="BtnAddCharacter" Content="＋ 新增自定义角色" Style="{StaticResource OutlineButton}"/>
        <Button x:Name="BtnAddReply" Content="＋ 新增自定义回复" Style="{StaticResource OutlineButton}"/>
      </StackPanel>
    </Grid>

    <StackPanel Grid.Row="2" Margin="0,16,0,0">
      <TextBlock x:Name="StatusText" Text="" FontSize="12" Foreground="#00B894" Margin="0,0,0,10"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="BtnStartStop" Content="开始运行" Style="{StaticResource StartStopButton}" Width="100" Height="34" FontSize="13" Margin="0,0,10,0"/>
        <Button x:Name="BtnSave" Content="保存设置" Style="{StaticResource PrimaryButton}" Width="100" Height="34" FontSize="13"/>
      </StackPanel>
    </StackPanel>
  </Grid>
</Window>